

APP_NAME=MindSprint AI Backend
DEBUG=True

# The URL of your Next.js frontend (for CORS)
FRONTEND_URL=http://localhost:3000

# Secret key — change this to something random in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-me-in-production

# ── Groq AI ────────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com
# Used by: POST /study/generate  (model: llama-3.3-70b-versatile)
# If left blank the endpoint returns mock data instead of real AI content.
GROQ_API_KEY=your_groq_api_key_here

# ── Database ───────────────────────────────────────────────────
# Supabase PostgreSQL — get your connection string from:
# Supabase Dashboard → Project → Settings → Database → Connection string → URI
# Use the "Transaction pooler" URL (port 6543) for best compatibility with FastAPI.
#
# Format:
#   postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
